# IPB Expertise — variables d'environnement
# Copier ce fichier en `.env.local` (déjà gitignoré via `.env*.local`)
# Documentation complète : ENV_VARIABLES.md et TRACKING.md

# ── Site ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Back-office CRM (/admin) ────────────────────────────────────
# Base PostgreSQL Neon — onglet "Connection string" du projet Neon.
# Utiliser l'URL "pooled" (…-pooler…) avec ?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require
# Secret de session Auth.js — générer avec : npx auth secret
AUTH_SECRET=
# Stockage des photos de rapports (Phase 3) — Vercel Blob
BLOB_READ_WRITE_TOKEN=
# Génération de rapports IA — clé API Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=
# Secret du cron de relances (Vercel l'envoie en `Authorization: Bearer <secret>`)
CRON_SECRET=

# ── Email (SMTP Gmail App Password) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@ipb-expertise.fr
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=contact@ipb-expertise.fr
EMAIL_TO=contact@ipb-expertise.fr

# ── Calendly ────────────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/contact-ipb-expertise/nouvelle-reunion

# ── Crisp Chat (optionnel) ──────────────────────────────────────
NEXT_PUBLIC_CRISP_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_CRISP_ENABLED=true

# ── Google Analytics 4 ──────────────────────────────────────────
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# ── Google Ads — Conversion tracking (voir TRACKING.md) ─────────
# ID du compte Ads, format AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX

# Action de conversion principale "Lead diagnostic" (campagne Fissures)
# Récupérer le couple AW-XXXX/labelXxxx dans Google Ads → Conversions
NEXT_PUBLIC_GADS_CONV_DIAGNOSTIC=AW-XXXXXXXXXX/labelDiagnostic

# Action de conversion principale "Lead calculateur" (campagne Mur Porteur)
NEXT_PUBLIC_GADS_CONV_CALCULATEUR=AW-XXXXXXXXXX/labelCalculateur

# Micro-conversions (optionnel — peuvent pointer sur la même action)
NEXT_PUBLIC_GADS_CONV_PHONE=AW-XXXXXXXXXX/labelPhone
NEXT_PUBLIC_GADS_CONV_CALLBACK=AW-XXXXXXXXXX/labelCallback

# ── Sentry (optionnel) ──────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
# Jeton du connecteur Cowork (MCP)
MCP_TOKEN=
